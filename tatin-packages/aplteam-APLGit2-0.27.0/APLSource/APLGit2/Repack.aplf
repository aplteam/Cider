 r‚ÜêRepack(folder args);rc;more;buff;cmd;a;d;f;depth;window
 a‚Üê0 args.Switch'a'
 d‚Üê0 args.Switch'd'
 f‚Üê0 args.Switch'f'
 depth‚Üê50 args.Switch'depth'
 window‚Üê10 args.Switch'window'
 cmd‚Üê'repack '
 cmd,‚Üêa/'-a '
 cmd,‚Üêd/'-d '
 cmd,‚Üêf/'-f '
 cmd,‚Üê'--depth=',(‚çïdepth),' '
 cmd,‚Üê'--window=',(‚çïwindow),' '
 (rc more buff)‚Üêfolder U.RunGitCommand cmd
 more U.Assert 0=rc
 r‚Üêmore
‚çùDone
