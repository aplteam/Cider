 tempDir‚Üê‚àÜGetFolderInTempDir‚äÉ‚éïSI
 sourceFolder‚ÜêtempDir,'/APLSource'
 'Create!'FilesAndDirs.CheckPath sourceFolder
 (tempDir,'/cider.config')‚éïNCOPY(##.CiderConfig.HOME,'/TestData/cider.config.Foo')
 cfg‚Üê‚àÜGetJSON5 tempDir,'/cider.config'
 cfg.CIDER.init‚Üê'Init'
 cfg ‚àÜPutJSON5 tempDir,'/cider.config'
 (‚äÇ'Init' '‚àÜINIT‚Üê1')FilesAndDirs.NPUT tempDir,'/APLSource/Init.aplf'
 (‚äÇ'r‚ÜêHello' 'r‚Üê''World''')FilesAndDirs.NPUT sourceFolder,'/hello.aplf'

 ref‚Üê‚àÜGetRefToCommTools
 ref.AddAutomation'YesOrNo' 'ChangeCurrentDir@' 'n'
 ref.AddAutomation'YesOrNo' 'OpenAsWell@' 'y'
 (rc msg res)‚Üê‚àÜUCMD'CreateProject "',tempDir,'" # -noEdit -acceptConfig -ignoreUserExec -batch'
 Assert'World'‚â°#.Foo.Hello
 list‚ÜêFilesAndDirs.ListFiles2 tempDir
 ‚ÜíT.GoToTidyUp 1‚âÝ‚â¢list
 ‚ÜíT.GoToTidyUp ##.Cider.ConfigFilename‚â¢‚äÉ,/1‚Üì‚éïNPARTS 1‚äÉlist
 ‚ÜíT.GoToTidyUp 1‚âÝ#.Foo.‚àÜINIT
 res‚Üê‚àÜLINK'Break' '#.Foo'
 Assert res ‚àÜStartsWith'Unlinked:'
 #.‚éïEX'Foo'

 (‚äÇ'Init x' '‚àÜINIT‚Üê1')FilesAndDirs.NPUT(tempDir,'/APLSource/Init.aplf')1
 (rc msg res)‚Üê‚àÜUCMD'OpenProject "',tempDir,'" -ignoreUserExec -batch'
 Assert‚à®/'#.Foo'‚ç∑res
 ‚ÜíT.GoToTidyUp 1‚âÝ#.Foo.‚àÜINIT
 res‚Üê‚àÜLINK'Break' '#.Foo'
 Assert res ‚àÜStartsWith'Unlinked:'
 #.‚éïEX'Foo'

 (‚äÇ'{x} Init y' '‚àÜINIT‚Üê1')FilesAndDirs.NPUT(tempDir,'/APLSource/Init.aplf')1
 (rc msg res)‚Üê‚àÜUCMD'OpenProject "',tempDir,'" -ignoreUserExec -batch'
 Assert‚à®/'#.Foo'‚ç∑res
 ‚ÜíT.GoToTidyUp 1‚âÝ#.Foo.‚àÜINIT
 res‚Üê‚àÜLINK'Break' '#.Foo'
 Assert res ‚àÜStartsWith'Unlinked:'
 #.‚éïEX'Foo'

 (‚äÇ'{r}‚ÜêInit y' 'r‚Üê‚àÜINIT‚Üê1')FilesAndDirs.NPUT(tempDir,'/APLSource/Init.aplf')1
 (rc msg res)‚Üê‚àÜUCMD'OpenProject "',tempDir,'" -ignoreUserExec -batch'
 Assert‚à®/'#.Foo'‚ç∑res
 ‚ÜíT.GoToTidyUp 1‚âÝ#.Foo.‚àÜINIT
 res‚Üê‚àÜLINK'Break' '#.Foo'
 Assert res ‚àÜStartsWith'Unlinked:'
 #.‚éïEX'Foo'

 (‚äÇ'x Init y' '‚àÜINIT‚Üê1')FilesAndDirs.NPUT(tempDir,'/APLSource/Init.aplf')1
 (rc msg res)‚Üê‚àÜUCMD'OpenProject "',tempDir,'" -ignoreUserExec -batch -verbose'
 ‚ÜíT.GoToTidyUp~0<#.‚éïNC'Foo'

 R‚ÜêT._OK

‚àÜTidyUp:
 ref.Cleanup
 res‚Üê‚àÜLINK'Break' '#.Foo'
