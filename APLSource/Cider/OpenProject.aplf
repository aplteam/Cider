 (successFlag ‚àÜLOG)‚ÜêOpenProject y;parms;configFilename;config;bool;res;linkOptions;source;p;dmx;projectSpace_;parms;fn;qdmx;pkgStatus;buff;nugetFolder;msg;flag;ref2TatinVars;‚àÜProblems;loadDependencies
‚çù Open a Cider project.\\
‚çù `y` must be one of:
‚çù  * a namespace holding all required parameters. Such a namespace can be created by calling `CreateOpenParms`
‚çù  * A character vector holding the full path to a project\\
‚çù The function returns either FAILURE or SUCCESS. This refers to the principal operation: opening the project.
‚çù If something like loading dependencies goes wrong, then messages are printed to the session in case batch‚Üê0.\\
‚çù In case `batch` is 1 things are different, however: in that case an error is thrown for all essential parts of
‚çù the operation. That includes loading any dependencies but excludes non-essential stuff like a Git status report.\\
‚çù The final message is "Project successfully [opened|imported and established in ... [with problems]". The
‚çù optional "with problems" part as added only when something like loading dependencies, or executing the package's
‚çù `lx` expression successfuly went wrong.
 successFlag‚ÜêFAILURE
 ‚àÜLOG‚Üê''                        ‚çù This is used to collect all messages
 ‚àÜProblems‚Üê0                    ‚çù Use as a counter of any problems; only relevant when batch‚Üê0
 :If 80=‚éïDR y
     parms‚ÜêCreateOpenParms''
     parms.folder‚Üêy
 :Else
     parms‚ÜêCreateOpenParms y
 :EndIf
 '"folder" must be specified'Assert 0<parms.‚éïNC'folder'
 '"folder" must be specified'Assert 0<‚â¢parms.folder
 parms.folder‚Üê{(~(1‚ç¥‚çµ)‚àä'/\')‚àß(~':'‚àä‚çµ)‚àß('[]'‚â¢‚çµ[1,‚â¢‚çµ]):‚ä¢F.EnforceSlash'expand'F.NormalizePath F.PWD,'/',‚çµ ‚ãÑ ‚çµ}{‚çµ‚Üì‚ç®+/‚àß\' '=‚çµ}parms.folder
 parms.folder‚ÜêF.NormalizePath parms.folder
 '"projectSpace" must be specified'Assert 0<parms.‚éïNC'projectSpace'
 '"watch" must be one of: ns|dir|both'Assert(‚äÇ‚éïC parms.watch)‚àä'ns' 'dir' 'both' 'none' 0
 p‚Üê{‚ç∫‚Üêparms.(verbose batch) ‚ãÑ ‚ç∫ PrintToSession ‚çµ}
 parms‚Üê(p GetFolderFromAlias)parms
 ('Folder does not exist: ',parms.folder)Assert F.Exists parms.folder
 p((1+parms.importFlag)‚äÉ'Loading' 'Importing'),' project from ',parms.folder
 parms.projectSpace‚Üê‚çïparms.projectSpace
 :If 0<‚â¢parms.parent
     parms.parent‚Üê,parms.parent
     'First level of parent must be either "#" or "‚éïSE"'Assert(‚äÜ1 ‚éïC{‚çµ‚Üë‚ç®¬Ø1+‚çµ‚ç≥'.'}parms.parent)‚àä,¬®'#' '‚éïSE'
     ('Parent namespace "',parms.parent,'" does not exist')Assert(9=‚éïNC parms.parent)‚à®(‚äÇ,1 ‚éïC parms.parent)‚àä,¬®'#' '‚éïSE'
 :EndIf
 :If 0<‚â¢parms.projectSpace
     ('"projectSpace" must not carry a "." (see "parent"')Assert 0='.'+.=parms.projectSpace
     'Project space is not a valid APL name'Assert{0::0 ‚ãÑ 0=(‚éïNS'').‚éïNC ‚çµ}‚çïparms.projectSpace
 :EndIf
 parms.alias‚Üê‚éïC parms.alias
 :If parms.alias‚â°'.'
     parms.alias‚Üê‚éïC 2‚äÉ{1 ‚éïNPARTS(-(¬Ø1‚Üë‚çµ)‚àä'/\')‚Üì‚çµ}parms.folder
 :EndIf
 AddAlias parms.folder parms.alias
 configFilename‚Üêparms.folder,'/cider.config'
 ('No file "cider.config" found in ',parms.folder)Assert F.Exists configFilename
 config‚ÜêReadProjectConfigFile configFilename
 config(CopyParms)‚Üêparms
 :If 0=‚â¢parms.projectSpace                                                      ‚çù Was it specified as argument?
 :AndIf 0=‚â¢parms.projectSpace‚Üêconfig.CIDER.projectSpace                         ‚çù Nope, so the config file rules...
     parms.projectSpace‚Üê'#'                                                     ‚çù ... but only is it is not empty
 :EndIf
 :If 0=‚â¢parms.parent                                                            ‚çù Was it specified as argument?
     parms.parent‚Üêconfig.CIDER.parent                                           ‚çù Nope, so the config file rules
 :EndIf
 :If 0=‚â¢parms.projectSpace
     projectSpace_‚Üê‚çéparms.parent                                                ‚çù Is either # or ‚éïSE
 :Else
     :If ~(,‚äÇ1 ‚éïC parms.parent)‚àä,¬®'#' '‚éïSE'
         ('Namespace <',parms.parent,'> does not exist')Assert 9=‚éïNC parms.parent
     :EndIf
     projectSpace_‚Üê‚çéparms.projectSpace(‚çéparms.parent).‚éïNS''                     ‚çù Create project space from "parent" to avoid problems
 :EndIf
 config‚ÜêprojectSpace_.‚éïNS config
 'Already opened?!'Assert~CheckForAlreadyOpened projectSpace_
 config‚Üêparms PolishProperties config
 config‚ÜêHandleLinkParameters config configFilename
 config‚ÜêCheckParameters config
 configFilename HandleSysVars config
 source‚Üêparms.folder,(0<‚â¢config.CIDER.source)/'/',config.CIDER.source           ‚çù For linking we are only interested in the code folder
 ('Source folder does not exist: ',parms.folder)Assert F.Exists parms.folder
 (linkOptions parms)‚ÜêProcessLinkOptions parms config
 p'Bringing in the source code...'
 projectSpace_‚ÜêCheckTargetNamespaceAndLinkFolder projectSpace_ parms config.CIDER.source
 :If parms.importFlag
     res‚ÜêlinkOptions ‚éïSE.Link.Import projectSpace_ source                       ‚çù Get the code into the WS
     dmx‚Üê‚éïDMX
     ('LINK failed to import the code (,',dmx.EM,')')Assert~‚à®/'Error:'‚ç∑res
     p'Code imported'
 :Else
     res‚ÜêlinkOptions ‚éïSE.Link.Create projectSpace_ source                       ‚çù Get the code into the WS
     dmx‚Üê‚éïDMX
     ('LINK failed to load the code (',dmx.EM,')')Assert~‚à®/'Error:'‚ç∑res
     ('LINK failed to load the code from <(',source,'>')Assert~‚à®/'Unknown Debug options in'‚ç∑res
     :If ‚à®/'ERRORS ENCOUNTERED:'‚ç∑res
         res Assert 0
     :EndIf
 :EndIf
 ‚çù --- Change of strategy: "watch is now handled like any other parameter: ---
 ‚çù Only reported when it is not set to the default.
 ‚çù (1 parms.batch)p 'watch'ReportLinkSettings linkOptions    ‚çù Exclude "watch"
 ‚çù 1 p parms.batch ReportWatch res                           ‚çù Always
 ‚çù ---------------------------------------------------------------------------
 (1 parms.batch)p ReportLinkSettings linkOptions
 :If 0=parms.noPkgLoad
     loadDependencies‚Üê1
     :If ¬Ø1=pkgStatus‚Üêparms CheckForTatinPackages config
         loadDependencies‚Üê0
     :EndIf
     :If 0<pkgStatus
         :If 0=parms.importFlag
             :Trap 0
                 CheckPackagesStatus config parms pkgStatus
             :Else
                 ‚éïSE._Tatin.Client.CloseConnections 1                           ‚çù Just in case...
                 qdmx‚Üê‚éïDMX
                 buff‚Üê''
                 buff,‚Üê‚äÇ'ERROR: Checking Tatin package status in ',parms.folder
                 buff,‚Üê‚äÇ' failed: ',{(1‚äÉ‚çµ),' in ',{‚çµ‚Üë‚ç®‚çµ‚ç≥']'}(2‚äÉ‚çµ)}qdmx.DM
                 ‚àÜProblems+‚Üê1
                 loadDependencies‚Üê0
                 (1‚Üì‚äÉ,/(‚éïUCS 13),¬®buff)Assert parms.batch
                 (1 parms.batch)p buff
             :EndTrap
         :EndIf
         :Trap 0
             :If loadDependencies
             :AndIf 0=parms.(verbose batch)LoadTatinDependencies config parms.folder(‚çïprojectSpace_)
                 buff‚Üê'Package folder ',parms.folder,' needs attention!'
                 ‚àÜProblems+‚Üê1
                 buff Assert~parms.batch
                 1 p buff
             :EndIf
         :Else
             ‚éïSE._Tatin.Client.CloseConnections 1                               ‚çù Just in case...
             qdmx‚Üê‚éïDMX
             buff‚Üê''
             buff,‚Üê‚äÇ'ERROR: loading Tatin packages from ',parms.folder
             buff,‚Üê‚äÇ' failed: ',{(1‚äÉ‚çµ),' in ',{‚çµ‚Üë‚ç®‚çµ‚ç≥']'}(2‚äÉ‚çµ)}qdmx.DM
             buff‚Üê1‚Üì‚äÉ,/(‚éïUCS 13),¬®buff
             ‚àÜProblems+‚Üê1
             buff Assert~parms.batch
             1 p buff
         :EndTrap
     :EndIf
     :If 0<config.‚éïNC'CIDER.dependencies.nuget'
     :AndIf 0<‚â¢config.CIDER.dependencies.nuget
         :If {(0<1‚äÉ‚çµ)‚àß2‚äÉ‚çµ}2250‚å∂0
             :Trap 11
                 {}parms.(verbose batch)LoadNuGetDependencies parms.folder projectSpace_
             :Else
                 ‚éïSE._Tatin.Client.CloseConnections 1                           ‚çù Just in case...
                 qdmx‚Üê‚éïDMX
                 buff‚Üê''
                 buff,‚Üê‚äÇ'ERROR: loading NuGet packages from ',parms.folder
                 buff,‚Üê‚äÇ' failed: ',{(1‚äÉ‚çµ),' in ',{‚çµ‚Üë‚ç®‚çµ‚ç≥']'}(2‚äÉ‚çµ)}qdmx.DM
                 ‚àÜProblems+‚Üê1
                 buff Assert~parms.batch
                 1 p buff
             :EndTrap
         :Else
             'Cannot load NuGet packages: .NET is not available'Assert~parms.batch
             1 p'Cannot load NuGet packages: .NET is not available'
         :EndIf
     :EndIf
 :EndIf
 InjectConfigDataIntoProject config projectSpace_ parms.folder
 ref2TatinVars‚ÜêInjectTatinVars projectSpace_ parms.folder
 parms HandleLX ref2TatinVars projectSpace_
 flag‚Üê(0=parms.batch)‚àß(0=parms.importFlag)
 {}ChangeCurrentDir‚ç£flag‚ä¢parms.folder
 {}parms ExecProjectInitFunction‚ç£(0=parms.suppressInit)‚ä¢config projectSpace_
 {}ExecUserFunction‚ç£((0=parms.importFlag)‚àß0=parms.ignoreUserExec)‚ä£config
