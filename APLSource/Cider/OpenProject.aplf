 successFlag‚ÜêSUCCESS
 {}CheckForDropboxConflicts‚ç£flag‚ä¢parms.folder
 {}CheckForGit‚ç£flag‚ä¢parms.folder config parms
 msg‚Üê'Project successfully ',(1+parms.importFlag)‚äÉ'opened' 'imported'
 :If 0<‚àÜProblems
     msg,‚Üê' (though with ',(‚çï‚àÜProblems),' problem',((1<‚àÜProblems)/'s'),')'
 :EndIf
 msg,‚Üê' and established in: ',parms.parent,{(,'#')‚â°,‚çµ:'' ‚ãÑ '.',‚çµ}parms.projectSpace
 p msg
‚çùDone
